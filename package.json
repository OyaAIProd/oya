{
  "name": "oya",
  "version": "0.1.0",
  "description": "A plan-don't-react framework for LLM agents. The model emits a typed dataflow plan once; the runtime executes it; the model never reads state it shouldn't. The TypeScript runtime built on projection types.",
  "license": "MIT",
  "author": "Oya Labs, Inc.",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18",
    "bun": ">=1.1"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./anthropic": {
      "types": "./dist/anthropic.d.ts",
      "import": "./dist/anthropic.js",
      "require": "./dist/anthropic.cjs"
    },
    "./openai": {
      "types": "./dist/openai.d.ts",
      "import": "./dist/openai.js",
      "require": "./dist/openai.cjs"
    },
    "./google": {
      "types": "./dist/google.d.ts",
      "import": "./dist/google.js",
      "require": "./dist/google.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:bench": "tsc -p benchmarks/tsconfig.json",
    "example": "bun examples/weather-report.ts",
    "bench": "bun benchmarks/compare.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "llm",
    "agents",
    "ai",
    "agent-framework",
    "plan-ir",
    "projection-types",
    "information-flow-control",
    "prompt-injection",
    "anthropic",
    "openai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oya-labs/oya.git"
  },
  "homepage": "https://github.com/oya-labs/oya#readme",
  "bugs": {
    "url": "https://github.com/oya-labs/oya/issues"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@mastra/core": "^1.36.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "ai": "^6.0.190",
    "react": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.5.0"
  },
  "trustedDependencies": [
    "esbuild"
  ]
}
