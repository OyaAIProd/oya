{
  "name": "oyadotai",
  "version": "0.1.4",
  "description": "A plan-don't-react framework for LLM agents. The model emits a typed dataflow plan once; the runtime executes it; the model never reads state it shouldn't.",
  "license": "MIT",
  "author": "Oya Labs, Inc.",
  "repository": { "type": "git", "url": "git+https://github.com/OyaAIProd/oya.git", "directory": "packages/core" },
  "homepage": "https://github.com/OyaAIProd/oya#readme",
  "bugs": { "url": "https://github.com/OyaAIProd/oya/issues" },
  "type": "module",
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "files": ["dist", "README.md"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "oya": "./dist/cli.js" },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./anthropic": { "types": "./dist/anthropic.d.ts", "import": "./dist/anthropic.js", "require": "./dist/anthropic.cjs" },
    "./openai": { "types": "./dist/openai.d.ts", "import": "./dist/openai.js", "require": "./dist/openai.cjs" },
    "./google": { "types": "./dist/google.d.ts", "import": "./dist/google.js", "require": "./dist/google.cjs" },
    "./react": { "types": "./dist/react.d.ts", "import": "./dist/react.js", "require": "./dist/react.cjs" },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && bun run build:studio",
    "build:studio": "vite build --config studio/vite.config.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "example": "bun examples/weather-report.ts",
    "demo": "bun examples/demo.ts"
  },
  "keywords": ["llm", "agents", "ai", "agent-framework", "plan-ir", "projection-types", "anthropic", "openai"],
  "dependencies": { "zod": "^3.23.8" },
  "peerDependencies": { "react": "^18 || ^19" },
  "peerDependenciesMeta": { "react": { "optional": true } },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.3.5",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.0",
    "vite": "^6.0.0"
  }
}
