{
  "name": "@oya/server",
  "version": "0.1.0",
  "description": "Fetch-API server helpers for oya agents (SSE / text streaming).",
  "license": "MIT",
  "author": "Oya Labs, Inc.",
  "type": "module",
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "files": ["dist", "README.md"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": { "oya": "*" },
  "devDependencies": {
    "oya": "workspace:*",
    "tsup": "^8.3.0"
  }
}
